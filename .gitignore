# ==============================================================================
# КОМПИЛЯЦИЯ PYTHON (Кэш интерпретатора)
# ==============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd

# ==============================================================================
# ВИРТУАЛЬНЫЕ ОКРУЖЕНИЯ (Зависимости проекта)
# ==============================================================================
venv/
.venv/
env/
ENV/
dist/
build/
*.egg-info/

# ==============================================================================
# УСТАНОВЩИК (собранные артефакты PyInstaller/Inno Setup — см. installer/build.ps1)
# ==============================================================================
# Промежуточные артефакты сборки (installer/dist, installer/build) — это
# распакованный PyInstaller-каталог (сотни файлов, ~230 МБ), он не нужен
# никому, кроме как временно при сборке, поэтому не пушится.
# А вот installer/output/*.exe — это уже готовый setup.exe, который раздаём
# другим людям для скачивания игры, поэтому он НЕ игнорируется и должен
# коммититься в репозиторий.
installer/dist/
installer/build/

# ==============================================================================
# НАСТРОЙКИ РЕДАКТОРОВ И IDE
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
.project
.pydevproject

# ==============================================================================
# МУСОР ОПЕРАЦИОННЫХ СИСТЕМ
# ==============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ==============================================================================
# ИГРОВЫЕ / PYGAME СПЕЦИФИЧНЫЕ ПРАВИЛА
# ==============================================================================
# Логи тестирования и крэш-дампы (если игра пишет логи в файл)
*.log
crash_dumps/

# Сохранения и локальные конфиги игрока (чтобы не затирать чужие сейвы при скачивании)
saves/
*savegame*
options.txt
config.local.ini

# ==============================================================================
# ИСХОДНИКИ АССЕТОВ (Опционально)
# ==============================================================================
# Если ты рисуешь графику в сторонних редакторах или делаешь музыку, 
# раскомментируй (удали знак #) строки ниже. В репозитории должны лежать 
# только готовые .png и .wav/.mp3, а тяжелые исходники проектов лучше не пушить.
# *.aseprite
# *.psd
# *.xcf
# *.blend